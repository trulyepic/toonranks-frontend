    "@types/react-google-recaptcha": "^2.1.9",
    "@types/react-helmet": "^6.1.11",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
